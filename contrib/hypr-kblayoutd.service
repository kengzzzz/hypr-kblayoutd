[Unit]
Description=Per-window keyboard layout daemon for Hyprland
Documentation=https://github.com/kengzzzz/hypr-kblayoutd
PartOf=graphical-session.target
After=graphical-session.target

[Service]
ExecStart=/usr/bin/hypr-kblayoutd
Restart=on-failure
RestartSec=1s
# uwsm convention; harmless under a plain systemd user session.
Slice=background-graphical.slice

[Install]
WantedBy=graphical-session.target
